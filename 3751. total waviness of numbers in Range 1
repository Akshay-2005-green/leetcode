class Solution(object):
    def totalWaviness(self, num1, num2):
        total = 0

        for num in range(num1, num2 + 1):
            s = str(num)

            waviness = 0

            for i in range(1, len(s) - 1):
                left = int(s[i - 1])
                mid = int(s[i])
                right = int(s[i + 1])

                if (left < mid > right) or (left > mid < right):
                    waviness += 1

            total += waviness

        return total
