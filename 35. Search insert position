class Solution(object):
    def searchInsert(self, nums, target):
        n = len(nums)
        st = 0
        end = n - 1

        while st <= end:
            mid = (st + end) // 2

            if nums[mid] == target:
                return mid

            elif target > nums[mid]:
                st = mid + 1
            else:
                end = mid - 1

        return st
